# ===== CONFIGURACIÓN DE PRODUCCIÓN =====
# Copia este archivo a .env y configura los valores para tu entorno

# ===== SEGURIDAD =====
# Cambiar a una clave segura y única en producción
JWT_SECRET=tu-clave-secreta-super-segura-cambiar-en-produccion

# ===== DATABASE =====
# PostgreSQL
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=tu-contraseña-segura-cambiar
POSTGRES_DB=auth_db
DATABASE_URL=postgresql://auth_user:tu-contraseña-segura-cambiar@postgres-auth:5432/auth_db

# ===== CACHE =====
# Redis
REDIS_URL=redis://redis-cache:6379

# ===== MESSAGE BROKER =====
# NATS
NATS_URL=nats://nats-server:4222

# ===== ENVIRONMENT =====
NODE_ENV=production

# ===== PUERTOS =====
API_GATEWAY_PORT=3000
AUTH_MS_PORT=3001
CIRCUITOS_MS_PORT=3002
ROTACIONES_MS_PORT=3003
NATS_PORT=4222
POSTGRES_PORT=5432
REDIS_PORT=6379
