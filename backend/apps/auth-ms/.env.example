# Auth Microservice Configuration
PORT=3002
NODE_ENV=development
NATS_URLS=nats://localhost:4222

# PostgreSQL Database Configuration - Local Development
# Use "localhost" for local development
# Use "postgres" for Docker Compose (network service name)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=auth_user
DB_PASSWORD=auth_password
DB_NAME=auth_db
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Redis Configuration - Local Development
# Use "localhost" for local development
# Use "redis" for Docker Compose (network service name)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_ACCESS_TOKEN_EXPIRES_IN=4h
JWT_REFRESH_TOKEN_EXPIRES_IN=15d
